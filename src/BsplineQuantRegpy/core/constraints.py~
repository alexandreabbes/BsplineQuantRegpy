import numpy as np
import cvxpy as cp


def apply_karlin_constraints_cubic(coeffs_cubic, monot_sign=1):
    """
    Applique les contraintes de Karlin pour un polynôme cubique (dérivée première)
    selon le théorème 3 de l'article.
    
    Parameters
    ----------
    coeffs_cubic : array-like
        Coefficients [a, b, c, d] pour a*u^3 + b*u^2 + c*u + d
    monot_sign : int
        +1 pour p(u) >= 0, -1 pour p(u) <= 0
    
    Returns
    -------
    list
        Liste des contraintes CVXPY
    """
    a, b, c, d = coeffs_cubic
    
    # Variables auxiliaires selon le théorème 3
    y0 = cp.Variable()
    y1 = cp.Variable()
    y2 = cp.Variable()
    x0 = cp.Variable()
    x1 = cp.Variable()
    x2 = cp.Variable()
    
    constraints = []
    
    # Équations (6a)-(6d)
    constraints.append(d == y0)
    constraints.append(c == 2 * y1 + x0 - y0)
    constraints.append(b == y2 + 2 * x1 - 2 * y1)
    constraints.append(a == x2 - y2)
    
    # Contraintes de cône second-order (6e)-(6f)
    constraints.append(cp.SOC(x0 + x2, cp.hstack([x0 - x2, 2 * x1])))
    constraints.append(cp.SOC(y0 + y2, cp.hstack([y0 - y2, 2 * y1])))
    
    # Contraintes aux bornes selon le signe
    if monot_sign > 0:
        constraints.append(d >= 0)                     # p(0) >= 0
        constraints.append(a + b + c + d >= 0)         # p(1) >= 0
    else:
        constraints.append(-d >= 0)                    # -p(0) >= 0
        constraints.append(-(a + b + c + d) >= 0)      # -p(1) >= 0
    
    return constraints


def apply_karlin_constraints_quadratic(coeffs_quad, const_sign=1):
    """
    Applique les contraintes de Karlin pour un polynôme quadratique (dérivée seconde)
    selon la Proposition 5 du document PDF.
    
    Parameters
    ----------
    coeffs_quad : array-like
        Coefficients [a, b, c] pour a*u^2 + b*u + c
    const_sign : int
        +1 pour p(u) >= 0, -1 pour p(u) <= 0
    
    Returns
    -------
    list
        Liste des contraintes CVXPY
    """
    # coeffs_quad = [a, b, c] pour a*u^2 + b*u + c
    # Notation PDF: p(x) = p0 + p1*x + p2*x^2
    # Donc: p0 = c, p1 = b, p2 = a
    p0, p1, p2 = coeffs_quad[2], coeffs_quad[1], coeffs_quad[0]
    
    # Matrices de Karlin
    K1 = np.array([[1, 0, -1, -1],
                   [0, 1, 0, -1]])
    K2 = np.array([1, 0, 1, 1])
    
    constraints = []
    
    if const_sign != 0:
        # Variable auxiliaire z0 >= 0
        z0 = cp.Variable()
        constraints.append(z0 >= 0)
        
        # Application du signe
        P = const_sign * np.array([p0, p1, p2, const_sign * z0])
        x1 = K2 @ P
        x2, x3 = K1 @ P
        
        # Contrainte SOC: x1 >= ||(x2, x3)||_2
        constraints.append(cp.SOC(x1, cp.hstack([x2, x3])))
    
    return constraints


def apply_val_constraints(const, sign=1):
    """
    Applique les contraintes de signe pour une valeur constante.
    
    Parameters
    ----------
    const : cvxpy.Variable or float
        Valeur à contraindre
    sign : int
        +1 pour const >= 0, -1 pour const <= 0
    
    Returns
    -------
    list
        Liste des contraintes CVXPY
    """
    constraints = []
    
    if sign > 0:
        constraints.append(const >= 0)
    elif sign < 0:
        constraints.append(const <= 0)
    
    return constraints