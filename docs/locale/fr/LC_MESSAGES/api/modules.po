msgstr ""

#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:80 of
msgid "*>>> # Régression avec spline quadratique et contrainte convexe*"
msgstr ""

#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:81 of
msgid "*>>> result = quantile_spline(x, y, knots, tau=0.5, degree=2, cv=1)*"
msgstr ""

#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:83 of
msgid "*>>> # Régression avec spline quartique et toutes les contraintes*"
msgstr ""

#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:84 of
msgid "*>>> result = quantile_spline(x, y, knots, tau=0.5, degree=4,*"
msgstr ""

#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:85 of
msgid "*...                          monot=1, cv=1, der3=1)*"
msgstr ""

#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:87 of
msgid "*>>> # Évaluer la spline*"
msgstr ""

#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:88 of
msgid "*>>> x_eval = np.linspace(0, 1, 200)*"
msgstr ""

#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:89 of
msgid "*>>> y_eval = result(x_eval)*"
msgstr ""

