msgid "*Exemples*"
msgstr ""

#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:68 of
msgid "*--------*"
msgstr ""

#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:69 of
msgid "*>>> import numpy as np*"
msgstr ""

#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:70 of
msgid "*>>> from BsplineQuantRegpy import quantile_spline*"
msgstr ""

#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:71
#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:76
#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:79
#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:82
#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:86 of
msgid "*>>>*"
msgstr ""

#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:72 of
msgid "*>>> # Générer des données*"
msgstr ""

#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:73 of
msgid "*>>> x = np.linspace(0, 1, 100)*"
msgstr ""

#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:74 of
msgid "*>>> y = 2*x + 0.2*np.sin(10*np.pi*x) + 0.05*np.random.randn(100)*"
msgstr ""

#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:75 of
msgid "*>>> knots = np.quantile(x, np.linspace(0, 1, 11))*"
msgstr ""

#: BsplineQuantRegpy.models.quantile_reg.quantile_spline:77 of
