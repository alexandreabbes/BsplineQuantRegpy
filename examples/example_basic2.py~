#!/usr/bin/env python
# -*- coding: utf-8 -*-

"""
Exemple basique d'utilisation de SplineCubicQuantile.
Peut être exécuté indépendamment ou chargé depuis la GUI.
"""

import numpy as np
import matplotlib.pyplot as plt
import sys
import os

# Ajouter le chemin du projet
PROJECT_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
SRC_PATH = os.path.join(PROJECT_ROOT, 'src')
if SRC_PATH not in sys.path:
    sys.path.insert(0, SRC_PATH)

try:
    from PysplineQuantReg import SplineCubicQuant
    print("✓ Module spline chargé")
except ImportError as e:
    print(f"✗ Erreur: {e}")
    SplineCubicQuant = None


def run_basic_example(show_plot=True):
    """
    Exécute l'exemple basique.
    
    Parameters
    ----------
    show_plot : bool
        Si True, affiche le graphique.
    
    Returns
    -------
    dict
        Résultats de l'exemple.
    """
    print("=" * 50)
    print("EXEMPLE BASIQUE - SPLINE CUBIQUE")
    print("=" * 50)
    
    # Générer des données
    np.random.seed(42)
    x = np.linspace(0, 1, 100)
    y = 3*x + 0.2*np.sin(10*np.pi*x) + 0.05*np.random.randn(100)
    knots = np.quantile(x, np.linspace(0, 1, 11))
    
    print(f"Nombre de points: {len(x)}")
    print(f"Nombre de nœuds: {len(knots)}")
    
    if SplineCubicQuant is None:
        print("❌ Module spline non disponible")
        return None
    
    # Régression sans contrainte
    print("\n--- Régression sans contrainte ---")
    result_none = SplineCubicQuant(x, y, knots, tau=0.5, 
                                   monot=0, cv=0, der3=0,
                                   solver='CLARABEL')
    
    # Régression avec contrainte croissante
    print("\n--- Régression avec contrainte croissante ---")
    result_monot = SplineCubicQuant(x, y, knots, tau=0.5,
                                    monot=1, cv=0, der3=0,
                                    solver='CLARABEL')
    
    # Régression avec contrainte croissante et convexe
    print("\n--- Régression avec contrainte croissante + convexe ---")
    result_both = SplineCubicQuant(x, y, knots, tau=0.5,
                                   monot=1, cv=1, der3=0,
                                   solver='CLARABEL')
    
    results = {
        'x': x,
        'y': y,
        'knots': knots,
        'none': result_none,
        'monot': result_monot,
        'both': result_both,
    }
    
    if show_plot and any(results[k] is not None for k in ['none', 'monot', 'both']):
        # Créer le graphique
        fig, axes = plt.subplots(1, 3, figsize=(15, 4))
        x_eval = np.linspace(0, 1, 200)
        
        # Sans contrainte
        ax = axes[0]
        ax.scatter(x, y, alpha=0.3, s=10, color='gray', label='Données')
        if result_none is not None:
            ax.plot(x_eval, result_none(x_eval), 'r-', linewidth=2, label='Spline')
        ax.plot(knots, np.ones_like(knots)*max(y)*0.95, 'k|', markersize=8, label='Nœuds')
        ax.set_title('Sans contrainte')
        ax.legend(fontsize='small')
        ax.grid(True, alpha=0.3)
        
        # Croissante
        ax = axes[1]
        ax.scatter(x, y, alpha=0.3, s=10, color='gray', label='Données')
        if result_monot is not None:
            ax.plot(x_eval, result_monot(x_eval), 'g-', linewidth=2, label='Spline')
        ax.plot(knots, np.ones_like(knots)*max(y)*0.95, 'k|', markersize=8, label='Nœuds')
        ax.set_title('Contrainte croissante')
        ax.legend(fontsize='small')
        ax.grid(True, alpha=0.3)
        
        # Croissante + Convexe
        ax = axes[2]
        ax.scatter(x, y, alpha=0.3, s=10, color='gray', label='Données')
        if result_both is not None:
            ax.plot(x_eval, result_both(x_eval), 'b-', linewidth=2, label='Spline')
        ax.plot(knots, np.ones_like(knots)*max(y)*0.95, 'k|', markersize=8, label='Nœuds')
        ax.set_title('Croissante + Convexe')
        ax.legend(fontsize='small')
        ax.grid(True, alpha=0.3)
        
        plt.tight_layout()
        plt.show()
    
    print("\n✅ Exemple terminé")
    return results


if __name__ == "__main__":
    # Exécution indépendante
    results = run_basic_example(show_plot=True)
